# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# PostgreSQL (Docker)
POSTGRES_DB=reception
POSTGRES_USER=reception
POSTGRES_PASSWORD=your-secure-password

# Database URL (for local development without Docker)
# DATABASE_URL=postgres://user:password@localhost:5432/reception

# Telnyx (Primary provider)
# API key and public key are account-level credentials
# Connection IDs and Assistant IDs are per-agent, stored in the database
TELNYX_API_KEY=your_api_key
TELNYX_PUBLIC_KEY=your_public_key

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID_BASIC=price_basic
STRIPE_PRICE_ID_PRO=price_pro

# Webhook Base URL (public URL for webhooks)
BASE_WEBHOOK_URL=https://your-domain.com

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_ID=primary

# Cloudflare Tunnel
# Get this from: https://one.dash.cloudflare.com/ -> Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
