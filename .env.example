# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# PostgreSQL (Docker)
POSTGRES_DB=reception
POSTGRES_USER=reception
POSTGRES_PASSWORD=your-secure-password

# Database URL (for local development without Docker)
# DATABASE_URL=postgres://user:password@localhost:5432/reception

# Twilio (Master Account - used for provisioning tenant phone numbers)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Vapi.ai (used for provisioning tenant assistants)
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_SECRET=
VAPI_DEFAULT_SYSTEM_PROMPT=You are a helpful AI receptionist. Greet the caller, ask how you can help, and collect their name and reason for calling.

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID_BASIC=price_basic
STRIPE_PRICE_ID_PRO=price_pro

# Webhook Base URL (public URL for configuring Twilio webhooks)
BASE_WEBHOOK_URL=https://your-domain.com

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_ID=primary

# Cloudflare Tunnel
# Get this from: https://one.dash.cloudflare.com/ -> Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
