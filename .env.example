# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# PostgreSQL (Docker)
POSTGRES_DB=reception
POSTGRES_USER=reception
POSTGRES_PASSWORD=your-secure-password

# Database URL (for local development without Docker)
# DATABASE_URL=postgres://user:password@localhost:5432/reception

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
FORWARD_PHONE_NUMBER=+1234567890

# Vapi.ai
VAPI_ASSISTANT_PHONE_NUMBER=+1234567890
VAPI_WEBHOOK_SECRET=

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_ID=primary

# Cloudflare Tunnel
# Get this from: https://one.dash.cloudflare.com/ -> Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
